# Production environment variables
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=production
APP_NAME=DevWithSunil

# Database (PostgreSQL)
DATABASE_URL=postgresql://username:password@host:port/database

# JWT
JWT_SECRET=your-very-long-random-secret-key-minimum-32-characters-here-make-it-very-secure
JWT_EXPIRATION=4h

# CORS - Set to your frontend URL in production
FRONTEND_URL=https://devwithsunil.vercel.app/

# Email (nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=sunilkvb44@gmail.com
EMAIL_PASS=admin@123
EMAIL_TO=sunilkvb44@gmail.com

# Optional: Analytics, error tracking, etc
# SENTRY_DSN=https://your-sentry-dsn
