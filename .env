# Production environment variables
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=production
APP_NAME=DevWithSunil

# Database (PostgreSQL)
DB_HOST=your-db-host.neon.tech
DB_PORT=5432
DB_DATABASE=devwithsunil_db
DB_USER=devwithsunil_user
DB_PASSWORD=your-strong-password-here

# JWT
JWT_SECRET=your-very-long-random-secret-key-minimum-32-characters
JWT_EXPIRATION=4h

# CORS - Set to your frontend URL in production
CORS_ORIGIN=https://your-frontend-domain.com

# Email (nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password-here
EMAIL_TO=admin@example.com

# Optional: Analytics, error tracking, etc
# SENTRY_DSN=https://your-sentry-dsn
